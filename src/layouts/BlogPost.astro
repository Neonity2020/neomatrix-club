---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  cover?: string;
}

const { title, description, pubDate, updatedDate, tags = [], author = 'Neomatrix 团队', cover } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Neomatrix Blog`} description={description}>
  <div class="blog-page">
    <div class="container">
      <!-- Back link -->
      <a href="/blog" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        返回博客
      </a>

      <article class="island post-island">
        <!-- Header -->
        <header class="post-header">
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map(tag => (
                <a href={`/blog/tag/${tag}`} class="tag tag--primary">{tag}</a>
              ))}
            </div>
          )}
          <h1 class="post-title">{title}</h1>
          <p class="post-desc">{description}</p>
          <div class="post-meta">
            <span class="post-author">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              {author}
            </span>
            <span class="post-date">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {formattedPubDate}
              {formattedUpdatedDate && <span class="updated-tag">· 更新于 {formattedUpdatedDate}</span>}
            </span>
          </div>
        </header>

        {cover && (
          <div class="post-cover">
            <img src={cover} alt={title} class="post-cover__img" />
          </div>
        )}

        <hr class="post-divider" />

        <!-- Content -->
        <div class="post-content">
          <slot />
        </div>

        <hr class="post-divider" />

        <!-- Footer -->
        <footer class="post-footer">
          <div class="post-footer-tags">
            {tags.map(tag => (
              <a href={`/blog/tag/${tag}`} class="tag tag--primary">{tag}</a>
            ))}
          </div>
          <a href="/blog" class="btn btn--ghost btn--sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            查看更多文章
          </a>
        </footer>
      </article>

      <!-- CTA Banner -->
      <div class="island cta-banner">
        <div class="cta-banner__content">
          <p class="section-eyebrow">加入社区</p>
          <h2 class="cta-banner__title">和同频的人一起成长</h2>
          <p class="cta-banner__desc">Neomatrix 是超级个体的聚集地。AI 工具 · 一人公司 · 终身成长，每周有新内容和活动。</p>
          <a href="/#pricing" class="btn btn--primary">立即加入</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-page {
    min-height: 100vh;
    padding: 40px 0 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
    transition: gap 0.2s;
  }
  .back-link:hover { gap: 10px; }

  .post-island {
    margin-bottom: 16px;
  }

  .post-header {
    margin-bottom: 32px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .post-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-bottom: 16px;
  }

  .post-desc {
    font-size: 18px;
    color: var(--gray-500);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .post-author,
  .post-date {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--gray-500);
  }

  .updated-tag {
    color: var(--gray-400);
  }

  .post-cover {
    margin: 0 0 8px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .post-cover__img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
    box-shadow: var(--shadow-md);
  }

  .post-divider {
    border: none;
    border-top: 1px solid rgba(109, 40, 217, 0.08);
    margin: 32px 0;
  }

  /* --- Article Prose Styles --- */
  .post-content {
    font-size: 17px;
    line-height: 1.85;
    color: var(--gray-700);
  }

  .post-content :global(h2) {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--black);
    margin: 2.5em 0 0.8em;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--primary-pale);
  }

  .post-content :global(h3) {
    font-size: 20px;
    font-weight: 700;
    color: var(--black);
    margin: 2em 0 0.6em;
  }

  .post-content :global(p) {
    margin-bottom: 1.4em;
  }

  .post-content :global(strong) {
    color: var(--black);
    font-weight: 700;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.2em 0 1.4em 1.2em;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-content :global(li) {
    padding-left: 4px;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    background: var(--primary-pale);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 16px 20px;
    margin: 1.5em 0;
    color: var(--primary-dark);
    font-style: italic;
  }

  .post-content :global(code) {
    background: var(--primary-pale);
    color: var(--primary-dark);
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.88em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .post-content :global(pre) {
    background: var(--gray-900);
    color: #e5e7eb;
    padding: 20px 24px;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 14px;
    line-height: 1.7;
  }

  .post-content :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 15px;
  }

  .post-content :global(th) {
    background: var(--primary-pale);
    color: var(--primary-dark);
    font-weight: 700;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 2px solid rgba(109, 40, 217, 0.15);
  }

  .post-content :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid var(--gray-100);
    color: var(--gray-700);
  }

  .post-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .post-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--gray-100);
    margin: 2.5em 0;
  }

  .post-content :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    margin: 1.5em 0;
  }

  /* Footer */
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .post-footer-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* CTA Banner */
  .cta-banner {
    text-align: center;
    padding: 56px 40px;
    background: linear-gradient(135deg, var(--primary-pale) 0%, rgba(255,255,255,1) 100%);
  }

  .cta-banner__title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-bottom: 12px;
  }

  .cta-banner__desc {
    font-size: 16px;
    color: var(--gray-500);
    max-width: 480px;
    margin: 0 auto 28px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .blog-page { padding: 24px 0 60px; }
    .post-footer { flex-direction: column; align-items: flex-start; }
    .cta-banner { padding: 40px 24px; }
  }
</style>
