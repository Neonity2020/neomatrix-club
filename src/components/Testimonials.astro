---
const testimonials = [
  {
    name: '陈宇轩',
    role: '前大厂产品经理 → 独立顾问',
    quote: '加入俱乐部 6 个月后，我从月薪 2 万的打工人，变成了月收入 5 万的独立顾问。最关键的不是方法论，而是找到了一群真的在做这件事的人。',
    stars: 5,
    featured: true,
    avatar: 'C',
    color: '#6D28D9',
  },
  {
    name: '林晓雯',
    role: '设计师 · 内容创作者',
    quote: '我花了一年时间看碎片化内容，什么都懂一点，什么都做不成。在这里学到的第一件事是：聚焦。现在我有了 3000 付费订阅用户。',
    stars: 5,
    featured: false,
    avatar: 'L',
    color: '#10B981',
  },
  {
    name: '王浩明',
    role: '软件工程师 · 副业月入 3 万',
    quote: '俱乐部里的 AI 工具库太实用了。我用里面推荐的工具组合，把原来要一整天的开发工作压缩到 2 小时，省下的时间全用来做副业。',
    stars: 5,
    featured: false,
    avatar: 'W',
    color: '#F59E0B',
  },
  {
    name: '张明远',
    role: '咨询顾问 · 一人公司创始人',
    quote: '以前觉得一个人做不成事。现在我的公司月流水稳定在 15 万，团队就是我自己 + 几个 AI 工具。思维转变比任何技能都重要。',
    stars: 5,
    featured: false,
    avatar: 'Z',
    color: '#3B82F6',
  },
  {
    name: '刘若溪',
    role: '自由撰稿人 · 知识产品创始人',
    quote: '在这里学会了如何把知识系统化变现。我的第一个付费专栏 3 天卖出 200 份，收入超过了我三个月的工资。这一切发生在我加入三个月后。',
    stars: 5,
    featured: false,
    avatar: '刘',
    color: '#EC4899',
  },
  {
    name: '赵子豪',
    role: '前运营总监 → 个人 IP 创业者',
    quote: '最大的收获不是方法，而是心态。这里有一群真的在做的人，每次想放弃的时候，看看群里大家的动态，就又有力气继续了。',
    stars: 5,
    featured: false,
    avatar: 'Z',
    color: '#EF4444',
  },
];
---

<section class="testimonials section" id="testimonials">
  <div class="container">
    <div class="testimonials__island island">
      <div class="testimonials__header" data-animate>
        <p class="section-eyebrow">会员故事</p>
        <h2 class="section-title">他们已经先走一步了</h2>
        <p class="section-desc">真实的会员，真实的改变。不是培训机构的套话，是这些人的真实经历。</p>
      </div>

      <div class="testimonials__grid">
        {testimonials.map((t, i) => (
          <div class:list={['testimonials__card', t.featured && 'testimonials__card--featured']} data-animate style={`--delay: ${i * 80}ms`}>
            {t.featured && <div class="testimonials__badge">精选故事</div>}
            <div class="testimonials__stars">{'★'.repeat(t.stars)}</div>
            <p class="testimonials__quote">"{t.quote}"</p>
            <div class="testimonials__author">
              <div class="testimonials__avatar" style={`background: linear-gradient(135deg, ${t.color}, ${t.color}99)`}>
                {t.avatar}
              </div>
              <div>
                <div class="testimonials__name">{t.name}</div>
                <div class="testimonials__role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials__island {
    padding: 80px 64px;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .testimonials__header .section-desc {
    margin: 0 auto;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .testimonials__card {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s ease;
    position: relative;
  }

  .testimonials__card:hover {
    background: white;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .testimonials__card--featured {
    grid-column: span 2;
    background: var(--primary-pale);
    border-color: rgba(109,40,217,0.15);
  }

  .testimonials__card--featured:hover {
    background: var(--primary-pale);
  }

  .testimonials__badge {
    display: inline-flex;
    align-items: center;
    background: var(--primary);
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    width: fit-content;
  }

  .testimonials__stars {
    color: #FFB800;
    font-size: 14px;
    letter-spacing: 2px;
  }

  .testimonials__quote {
    font-size: 15px;
    color: var(--gray-700);
    line-height: 1.75;
    flex: 1;
  }

  .testimonials__card--featured .testimonials__quote {
    font-size: 17px;
    color: var(--primary-dark);
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .testimonials__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--black);
  }

  .testimonials__role {
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }
  [data-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .testimonials__card--featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .testimonials__island {
      padding: 40px 16px;
    }
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
    .testimonials__card--featured {
      grid-column: span 1;
    }
    .testimonials__header {
      margin-bottom: 40px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.testimonials [data-animate]').forEach(el => observer.observe(el));
</script>
