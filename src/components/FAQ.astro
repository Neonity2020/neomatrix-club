---
const faqs = [
  {
    q: '我没有什么特别的技能，适合加入吗？',
    a: '这正是很多人加入的原因。俱乐部里有系统的能力诊断工具，帮你找到你的高价值组合——很多时候我们低估了自己已有的知识和经验的市场价值。',
  },
  {
    q: '加入后多久能看到效果？',
    a: '因人而异，但大多数会员在第一个月内就会有具体的认知转变和行动计划。看到收入变化通常在 3-6 个月，这取决于你投入的精力和执行力。我们不承诺速成，但承诺你走在正确的路上。',
  },
  {
    q: '这和其他成长社群有什么不同？',
    a: '大部分社群给你的是内容，我们给你的是系统。我们不堆砌信息，而是提供可执行的方法论、真实的工具评测和一群真的在做事的人。我们的重点是帮你找到和执行你自己的路径，而不是照搬别人的成功故事。',
  },
  {
    q: '内容更新频率是怎样的？',
    a: '每周发布 AI 工具评测通讯，每月更新实战方法论内容，每季度出一份深度行业报告。核心课程体系持续迭代，所有历史内容都可访问。',
  },
  {
    q: '我是全职工作，有时间参与吗？',
    a: '俱乐部的设计前提就是"时间有限的人"。每周核心内容消化需要 2-3 小时，全部异步，没有强制直播打卡。你按自己的节奏来，我们有完整的异步资料支持。',
  },
  {
    q: '可以开发票吗？支持什么支付方式？',
    a: '支持微信支付、支付宝，企业用户可开增值税发票。如需企业团购，联系我们获取定制方案。',
  },
  {
    q: '退款政策是什么？',
    a: '加入后 7 天内，如果你觉得不合适，全额退款，不问原因。之后按剩余天数比例退款。我们对自己的内容质量有信心，所以才能这么说。',
  },
];
---

<section class="faq section" id="faq">
  <div class="container">
    <div class="faq__island island">
      <div class="faq__header" data-animate>
        <p class="section-eyebrow">常见问题</p>
        <h2 class="section-title">你可能想问的问题</h2>
      </div>

      <div class="faq__list">
        {faqs.map((item, i) => (
          <div class="faq__item" data-animate style={`--delay: ${i * 60}ms`}>
            <button class="faq__question" aria-expanded="false">
              <span>{item.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="faq__answer">
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq__island {
    padding: 80px 64px;
  }

  .faq__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .faq__list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq__item {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .faq__item:first-of-type {
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    background: none;
    text-align: left;
    font-size: 16px;
    font-weight: 600;
    color: var(--black);
    cursor: pointer;
    transition: color 0.2s;
  }

  .faq__question:hover {
    color: var(--primary);
  }

  .faq__question[aria-expanded="true"] {
    color: var(--primary);
  }

  .faq__icon {
    flex-shrink: 0;
    color: var(--gray-400);
    transition: transform 0.25s ease;
  }

  .faq__question[aria-expanded="true"] .faq__icon {
    transform: rotate(180deg);
    color: var(--primary);
  }

  .faq__answer {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq__answer.open {
    max-height: 240px;
    padding-bottom: 20px;
  }

  .faq__answer p {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.75;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }
  [data-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .faq__island {
      padding: 40px 16px;
    }
    .faq__header {
      margin-bottom: 36px;
    }
    .faq__question {
      font-size: 15px;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__question').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling?.classList.remove('open');
      });
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling?.classList.add('open');
      }
    });
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 60);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.faq [data-animate]').forEach(el => observer.observe(el));
</script>
