---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))];

  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter(post => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Layout title={`#${tag} — Neomatrix Blog`} description={`关于"${tag}"的所有文章`}>
  <div class="tag-page">
    <div class="container">

      <!-- Back -->
      <a href="/blog" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        全部文章
      </a>

      <!-- Header -->
      <div class="island tag-hero">
        <div class="tag tag--dark" style="font-size:14px;margin-bottom:16px;"># {tag}</div>
        <h1 class="section-title" style="margin-bottom:8px;">{tag}</h1>
        <p class="section-desc">{posts.length} 篇文章</p>
      </div>

      <!-- Posts -->
      <div class="posts-list">
        {posts.map(post => (
          <article class="card post-row">
            <a href={`/blog/${post.slug}`} class="post-row__link">
              <div class="post-row__body">
                <h2 class="post-row__title">{post.data.title}</h2>
                <p class="post-row__desc">{post.data.description}</p>
                <div class="post-row__meta">
                  <span>{post.data.author}</span>
                  <span>·</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
              </div>
              <svg class="post-row__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </article>
        ))}
      </div>

    </div>
  </div>
</Layout>

<style>
  .tag-page {
    min-height: 100vh;
    padding: 40px 0 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
    transition: gap 0.2s;
  }
  .back-link:hover { gap: 10px; }

  .tag-hero { margin-bottom: 16px; }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post-row__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 28px;
  }

  .post-row__body { flex: 1; }

  .post-row__title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .post-row:hover .post-row__title { color: var(--primary); }

  .post-row__desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.6;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-row__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--gray-400);
  }

  .post-row__arrow {
    color: var(--primary);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s;
  }
  .post-row:hover .post-row__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .tag-page { padding: 24px 0 60px; }
    .post-row__link { padding: 18px 20px; }
  }
</style>
