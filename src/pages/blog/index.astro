---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all tags
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))].sort();
---

<Layout title="博客 — Neomatrix Club" description="超级个体 · 一人公司 · AI 工具 · 终身成长。Neomatrix 的深度文章与实战分享。">
  <div class="blog-index">
    <div class="container">

      <!-- Hero -->
      <div class="island blog-hero">
        <span class="section-eyebrow">Neomatrix Blog</span>
        <h1 class="section-title">洞察 · 方法 · 实战</h1>
        <p class="section-desc">超级个体的成长记录：AI 工具、一人公司、终身学习。每周更新，拒绝水内容。</p>
        <a href="/rss.xml" class="rss-link" target="_blank">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          订阅 RSS
        </a>
      </div>

      <!-- Tags Filter -->
      {allTags.length > 0 && (
        <div class="tags-section">
          <span class="tags-label">按话题浏览：</span>
          <div class="tags-list">
            <a href="/blog" class="tag tag--dark">全部</a>
            {allTags.map(tag => (
              <a href={`/blog/tag/${tag}`} class="tag tag--primary">{tag}</a>
            ))}
          </div>
        </div>
      )}

      <!-- Posts Grid -->
      <div class="posts-grid">
        {allPosts.map((post, i) => (
          <article class={`card post-card ${i === 0 ? 'post-card--featured' : ''} ${post.data.cover ? 'post-card--has-cover' : ''}`}>
            <a href={`/blog/${post.slug}`} class="post-card__link">
              {post.data.cover && (
                <div class="post-card__cover">
                  <img src={post.data.cover} alt={post.data.title} class="post-card__cover-img" loading="lazy" />
                </div>
              )}
              <div class="post-card__body">
                <div class="post-card__tags">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="tag tag--primary">{tag}</span>
                  ))}
                </div>
                <h2 class="post-card__title">{post.data.title}</h2>
                <p class="post-card__desc">{post.data.description}</p>
                <div class="post-card__footer">
                  <div class="post-card__meta">
                    <span>{post.data.author}</span>
                    <span>·</span>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                  <div class="post-card__arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      {allPosts.length === 0 && (
        <div class="island empty-state">
          <p>暂无文章，敬请期待。</p>
        </div>
      )}

    </div>
  </div>
</Layout>

<style>
  .blog-index {
    min-height: 100vh;
    padding: 40px 0 80px;
  }

  /* Hero */
  .blog-hero {
    margin-bottom: 16px;
    position: relative;
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 20px;
    color: var(--primary);
    font-size: 13px;
    font-weight: 600;
    padding: 8px 14px;
    border: 1.5px solid var(--primary);
    border-radius: 100px;
    transition: all 0.2s;
  }
  .rss-link:hover {
    background: var(--primary);
    color: white;
  }

  /* Tags filter */
  .tags-section {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    padding: 0 4px;
  }

  .tags-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-500);
    white-space: nowrap;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .post-card--featured {
    grid-column: 1 / -1;
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
  }

  /* Cover image */
  .post-card__cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-card__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .post-card:hover .post-card__cover-img {
    transform: scale(1.04);
  }

  .post-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 24px 28px;
  }

  .post-card--has-cover .post-card__body {
    padding: 20px 24px;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .post-card__title {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--black);
    line-height: 1.3;
    margin-bottom: 10px;
    transition: color 0.2s;
  }

  .post-card--featured .post-card__title {
    font-size: clamp(22px, 3vw, 32px);
    margin-bottom: 12px;
  }

  .post-card:hover .post-card__title {
    color: var(--primary);
  }

  .post-card__desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card--featured .post-card__desc {
    font-size: 16px;
    -webkit-line-clamp: 3;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--gray-400);
  }

  .post-card__arrow {
    color: var(--primary);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s;
  }

  .post-card:hover .post-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Empty */
  .empty-state {
    text-align: center;
    color: var(--gray-500);
    padding: 60px;
  }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
    .post-card--featured { grid-column: 1; }
    .post-card__link { padding: 20px; }
    .blog-index { padding: 24px 0 60px; }
    .tags-section { gap: 8px; }
  }
</style>
